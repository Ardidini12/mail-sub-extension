{
  "name": "Mail Subscription Manager",
  "description": "Manage your email subscriptions with ease - scan, view, and unsubscribe from newsletters",
  "version": "1.0.0",
  "manifest_version": 3,
  "action": {
    "default_popup": "src/ui/popup/popup.html",
    "default_icon": {
      "16": "assets/icons/icon16.png",
      "32": "assets/icons/icon32.png",
      "48": "assets/icons/icon48.png",
      "128": "assets/icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "src/background/service-worker.js",
    "type": "module"
  },
  "permissions": [
    "identity",
    "storage"
  ],
  "oauth2": {
    "client_id": "712079917136-o845a5a5difo6sf4qn5jpgm5d0al274a.apps.googleusercontent.com",
    "scopes": [
      "https://www.googleapis.com/auth/gmail.readonly"
    ]
  },
  "icons": {
    "16": "assets/icons/icon16.png",
    "32": "assets/icons/icon32.png",
    "48": "assets/icons/icon48.png",
    "128": "assets/icons/icon128.png"
  },
  "host_permissions": [
    "https://www.googleapis.com/*"
  ]
}
