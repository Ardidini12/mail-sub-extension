{
  "name": "mail-subscription-manager",
  "version": "1.0.0",
  "description": "Cross-platform browser extension for managing email subscriptions",
  "scripts": {
    "dev": "npm run dev:extension & npm run dev:backend",
    "dev:extension": "echo Extension development mode",
    "dev:backend": "cd backend && npm run dev",
    "build": "npm run build:extension",
    "build:extension": "echo Building extension",
    "test": "npm run test:extension && npm run test:backend",
    "test:extension": "echo Running extension tests",
    "test:backend": "cd backend && npm test"
  },
  "keywords": [
    "browser-extension",
    "email",
    "subscriptions",
    "unsubscribe",
    "gmail",
    "outlook",
    "chrome-extension"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "eslint": "^8.0.0",
    "prettier": "^3.0.0"
  }
}
